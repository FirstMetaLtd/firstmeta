RewriteEngine On

# Force HTTPS redirect (Disabled for Railway deployment since Railway handles SSL termination and forces HTTPS)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -d [OR]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Clean URL routing
RewriteRule ^home/?$ index.php [L,NC]
RewriteRule ^login/?$ login.php [L,NC]
RewriteRule ^register/?$ register.php [L,NC]
RewriteRule ^verify-email/?$ verify-email.php
RewriteRule ^team/?$ team.php
RewriteRule ^logout/?$ logout.php
RewriteRule ^products/?$ products.php
RewriteRule ^career/?$ career.php
RewriteRule ^privacy-policy/?$ privacy-policy.php
RewriteRule ^product/([^/]+)/?$ product.php?slug=$1 [L,QSA,NC]
RewriteRule ^about/?$ about.php
RewriteRule ^contact/?$ contact.php
RewriteRule ^services/?$ services.php
RewriteRule ^blogs/?$ blogs.php
RewriteRule ^blog/([^/]+)/?$ blog.php?slug=$1 [L,QSA,NC]
RewriteRule ^service/([^/]+)/?$ service.php?slug=$1 [L,QSA,NC]
RewriteRule ^apply/([^/]+)/?$ apply.php?job=$1 [L,QSA,NC]
RewriteRule ^forget-password/?$ forget-password.php
RewriteRule ^change-password/?$ change-password.php [L,NC]
RewriteRule ^register/([^/]+)/?$ ref-register.php?userid=$1 [L,QSA,NC]

ErrorDocument 404 /404.php

# ============================================================
# Security Headers
# ============================================================

# Prevent clickjacking
Header always set X-Frame-Options "SAMEORIGIN"

# Prevent MIME type sniffing
Header always set X-Content-Type-Options "nosniff"

# Enable XSS filter in older browsers
Header always set X-XSS-Protection "1; mode=block"

# Content Security Policy
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://pagead2.googlesyndication.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co; frame-ancestors 'self';"

# Referrer Policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# Hide PHP version
Header always unset X-Powered-By
ServerSignature Off

# ============================================================
# Block sensitive files from web access
# ============================================================
<FilesMatch "\.(env|log|sql|md|gitignore|json|lock|sh)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "^(Dockerfile|railway\.json|composer\..*)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect private directories
<IfModule mod_rewrite.c>
    RewriteRule ^private/ - [F,L]
    RewriteRule ^admin/private/ - [F,L]
</IfModule>